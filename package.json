{
  "name": "synthchat-workspace",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=22.14.0 <23",
    "npm": ">=10.9.2 <11"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cargo run --manifest-path backend/Cargo.toml",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend test",
    "test:coverage": "npm --prefix frontend run test:coverage",
    "test:e2e": "node scripts/e2e/run-local.mjs",
    "test:mixed-runtime": "node scripts/verify-mixed-runtime.mjs --smoke",
    "verify:mixed-runtime": "node scripts/verify-mixed-runtime.mjs --self-test",
    "verify:mixed-runtime-evidence:self-test": "node scripts/verify-mixed-runtime-evidence.mjs --self-test",
    "verify:mixed-runtime-evidence": "node scripts/verify-mixed-runtime-evidence.mjs --report docs/release-evidence/mixed-runtime-8h.json --manifest docs/release-evidence/mixed-runtime-8h.manifest.json",
    "verify:release-inputs": "node scripts/verify-release-inputs.mjs",
    "verify:release-ready": "node scripts/verify-release-inputs.mjs --require-clean --release-candidate",
    "prepare:sidecar": "node scripts/prepare-backend-sidecar.mjs",
    "build:desktop-assets": "npm run build && npm run prepare:sidecar",
    "desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-desktop.ps1",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-desktop.ps1",
    "desktop:build": "node scripts/run-tauri.mjs build"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
