{
    "$schema":  "https://raw.githubusercontent.com/nicholasrice/tauri/dev/crates/tauri-cli/schema.json",
    "productName":  "SynthChat",
    "version":  "1.1.0",
    "identifier":  "cc.synthchat.v1",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://127.0.0.1:1421",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "SynthChat V1.1.0",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "center":  true,
                                    "visible":  false,
                                    "dragDropEnabled":  false
                                }
                            ],
                "security":  {
                                 "csp":  "default-src 'self' asset: https: blob:; script-src 'self' 'unsafe-inline' asset: blob:; style-src 'self' 'unsafe-inline' asset:; img-src 'self' data: blob: asset: https:; font-src 'self' data: asset:; connect-src 'self' https: wss: asset:; media-src 'self' blob: asset: https:; frame-src 'none'; object-src 'none'; base-uri 'self'",
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  {
                                                                     "allow":  [
                                                                                   "$APPDATA/**",
                                                                                   "$APPCONFIG/**",
                                                                                   "$RESOURCE/**",
                                                                                   "$TEMP/**"
                                                                               ],
                                                                     "deny":  [
                                                                                   "$HOME/.ssh/**",
                                                                                   "$HOME/.gnupg/**",
                                                                                   "$HOME/.aws/**",
                                                                                   "$HOME/.config/gcloud/**"
                                                                              ]
                                                                }
                                                   }
                             },
                "macOSPrivateApi":  true
            },
    "bundle":  {
                   "active":  true,
                   "resources":  {
                                     "../skills":  "synthchat-data/skills",
                                     "../public":  "synthchat-data/public",
                                     "../data":  "synthchat-data/data"
                                 },
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "webviewInstallMode":  {
                                                              "type":  "offlineInstaller",
                                                              "silent":  true
                                                          }
                               }
               }
}
