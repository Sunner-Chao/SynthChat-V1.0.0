{
    "$schema":  "https://raw.githubusercontent.com/nicholasrice/tauri/dev/crates/tauri-cli/schema.json",
    "productName":  "SynthChat",
    "version":  "1.1.0",
    "identifier":  "cc.synthchat.v1",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://127.0.0.1:1421",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "SynthChat V1.1.0",
                                    "width":  1280,
                                    "height":  800,
                                    "minWidth":  900,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "center":  true,
                                    "visible":  false,
                                    "dragDropEnabled":  false
                                }
                            ],
                "security":  {
                                 "csp":  null,
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  {
                                                                     "allow":  [
                                                                                   "**"
                                                                               ],
                                                                     "deny":  [

                                                                              ]
                                                                }
                                                   }
                             },
                "macOSPrivateApi":  true
            },
    "bundle":  {
                   "active":  true,
                   "resources":  {
                                     "../skills":  "skills",
                                     "../public/pet":  "public/pet",
                                     "../data/tts":  "data/tts",
                                     "../data/emoji":  "data/emoji"
                                 },
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "webviewInstallMode":  {
                                                              "type":  "offlineInstaller",
                                                              "silent":  true
                                                          }
                               }
               }
}
